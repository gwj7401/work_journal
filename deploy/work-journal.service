[Unit]
Description=工作日志系统 - FastAPI后端
After=network.target mysql.service

[Service]
Type=simple
User=www
WorkingDirectory=/www/wwwroot/work-journal/backend
ExecStart=/www/wwwroot/work-journal/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8090 --workers 2
Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal

# 环境变量（与.env并存）
EnvironmentFile=/www/wwwroot/work-journal/backend/.env

[Install]
WantedBy=multi-user.target
